#
# set(CMAKE_C_COMPILER "/usr/bin/cc" CACHE FILEPATH "" FORCE)
# set(CMAKE_CXX_COMPILER "/usr/bin/c++" CACHE FILEPATH "" FORCE)
#
# set(CMAKE_PREFIX_PATH "/opt/homebrew" ${CMAKE_PREFIX_PATH})
